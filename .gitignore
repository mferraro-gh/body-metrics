# ── User data (never commit) ─────────────────────────────────────────────────
backend/**/*.db
backend/data/*.png
backend/data/*.jpg
backend/data/*.jpeg

# Keep the data directory itself
!backend/data/.gitkeep

# ── Python ───────────────────────────────────────────────────────────────────
backend/venv/
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.env

# ── ML models (EasyOCR / PyTorch — downloaded at runtime, never commit) ───────
*.pth
*.pt
*.onnx
*.bin
*.safetensors
*.h5

# ── Node ─────────────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
